// Custom colors
$accentColor = #3eaf7c
$textColor = #2c3e50
$borderColor = #eaecef
$codeBgColor = #282c34

// Custom styles
.home
  .hero
    img
      border-radius: 50%
      width: 200px
      height: 200px
      object-fit: cover

  .features
    border-top: 1px solid $borderColor
    padding: 1.2rem 0
    margin-top: 2.5rem

// Project cards styling
.projects-grid
  display: grid
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr))
  gap: 2rem
  margin: 2rem 0

.project-card
  border: 1px solid $borderColor
  border-radius: 8px
  padding: 1.5rem
  transition: transform 0.2s, box-shadow 0.2s
  
  &:hover
    transform: translateY(-2px)
    box-shadow: 0 4px 20px rgba(0,0,0,0.1)

// Responsive adjustments
@media (max-width: 719px)
  .home .hero
    img
      width: 150px
      height: 150px